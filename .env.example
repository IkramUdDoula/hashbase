# Gmail API Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:5000/oauth2callback

# Netlify API Credentials
# Configure Netlify via Settings > Secrets in the app (not in .env)

# News API Credentials
# Get a free API key from: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# CoinGecko API Credentials (Optional)
# CoinGecko offers a free tier with no API key required (50 calls/minute)
# For higher rate limits, get an API key from: https://www.coingecko.com/en/api/pricing
# VITE_COINGECKO_API_KEY=your_coingecko_api_key_here

# Frontend Configuration (for Vite)
VITE_FRONTEND_URL=http://localhost:5000

# Config Encryption Key (32-byte hex string for AES-256)
# Generate with: node generate-encryption-key.js
# This key is used to encrypt API secrets in exported config files
# Example: VITE_CONFIG_ENCRYPTION_KEY=cfcd868eeeecfe941addf4ca73214bbb25eaec2a635c292ba2223aeee297b7e0
VITE_CONFIG_ENCRYPTION_KEY=your_64_character_hex_key_here
