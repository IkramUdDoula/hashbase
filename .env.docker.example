# Docker Environment Configuration
# Copy this file to .env before running docker-compose

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://hashbase:hashbase_dev_password@postgres:5432/hashbase

# ============================================
# GMAIL API CREDENTIALS
# ============================================
# Get these from Google Cloud Console: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:5000/oauth2callback

# ============================================
# NEWS API (Optional)
# ============================================
# Get a free API key from: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_FRONTEND_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000

# ============================================
# CONFIG ENCRYPTION KEY
# ============================================
# Generate with: node generate-encryption-key.js
# This key is used to encrypt API secrets in exported config files
VITE_CONFIG_ENCRYPTION_KEY=your_64_character_hex_key_here

# ============================================
# ENVIRONMENT MODE
# ============================================
# Set to 'prod' to show landing page, 'dev' to show dashboard
VITE_ENV=dev
NODE_ENV=production

# ============================================
# SERVER PORT
# ============================================
PORT=5000

# ============================================
# LANDING PAGE FORM SUBMISSION (Optional)
# ============================================
# GitHub credentials for landing page form submissions
VITE_GITHUB_LANDING_TOKEN=your_github_token_here
VITE_GITHUB_LANDING_OWNER=your_github_username
VITE_GITHUB_LANDING_REPO=your_repo_name

# ============================================
# TMDB API (Optional)
# ============================================
# Get a free API key from: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here
